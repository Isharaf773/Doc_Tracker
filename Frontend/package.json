{
  "name": "doctrack-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:start": "cross-env ELECTRON_START_URL=http://localhost:5173 wait-on http://localhost:5173 && electron .",
    "electron:dev": "concurrently \"npm run dev\" \"npm run electron:start\"",
    "electron:build": "npm run build && electron-builder --win portable --x64"
  },
  "dependencies": {
    "electron": "^26.2.0",
    "jspdf": "^4.2.1",
    "jsqr": "^1.4.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "wait-on": "^9.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron-builder": "^24.7.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  },
  "build": {
    "appId": "com.geomine.doctrack",
    "productName": "DocTrack",
    "directories": {
      "output": "electron-dist"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ]
    }
  }
}
